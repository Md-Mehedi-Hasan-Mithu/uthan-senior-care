# Supabase — get these from https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# EmailJS — get these from https://emailjs.com → Account → API Keys
# Used in Contact form and ChatWidget
VITE_EMAILJS_SERVICE_ID=service_uthan
VITE_EMAILJS_TEMPLATE_CONTACT=template_contact
VITE_EMAILJS_TEMPLATE_CHAT=template_chat
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
